# ── Server ────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ────────────────────────────────
# Option 1: Local MongoDB
MONGO_URI=mongodb://localhost:27017/student_management

# Option 2: MongoDB Atlas (replace with your connection string)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/student_management?retryWrites=true&w=majority

# ── Frontend ───────────────────────────────
CLIENT_URL=http://localhost:5173
